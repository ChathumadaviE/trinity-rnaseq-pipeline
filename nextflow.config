// Default configuration
params {
    // Input/output
    reads = null
    outdir = './results'
    publish_dir_mode = 'copy'
    
    // Trinity parameters
    max_memory = '120.GB'
    max_cpus = 32
    max_time = '48.h'
    
    // Assembly parameters
    trinity_seqType = 'fq'  // 'fa' for fasta, 'fq' for fastq
    trinity_max_memory = '100G'
    trinity_cpu = 32
    
    // Trimmomatic parameters
    trimmomatic_adapters = 'TruSeq3-PE.fa'
    trimmomatic_options = 'ILLUMINACLIP:TruSeq3-PE.fa:2:30:10 LEADING:3 TRAILING:3 SLIDINGWINDOW:4:15 MINLEN:36'
    
    // Bowtie2 parameters
    bowtie2_threads = 8
    
    // Salmon parameters
    salmon_kmer = 31
    salmon_libType = 'A'  // Automatic
    
    // BUSCO parameters
    busco_lineage = 'eukarya'  // Can be changed based on organism
    
    // TransDecoder parameters
    transdecoder_min_prot_length = 100
    
    // Help
    help = false
}

// Profiles
profiles {
    standard {
        process {
            executor = 'local'
            cpus = { check_max( 2 * task.attempt, 'cpus' ) }
            memory = { check_max( 4.GB * task.attempt, 'memory' ) }
            time = { check_max( 24.h * task.attempt, 'time' ) }
            
            withLabel: heavy {
                cpus = { check_max( 8 * task.attempt, 'cpus' ) }
                memory = { check_max( 60.GB * task.attempt, 'memory' ) }
                time = { check_max( 48.h * task.attempt, 'time' ) }
            }
        }
    }
    
    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        
        process {
            container = 'trinity-rnaseq:latest'
            
            withName: FASTQC {
                container = 'biocontainers/fastqc:v0.11.9_cv7'
            }
            withName: TRIMMOMATIC {
                container = 'biocontainers/trimmomatic:0.39--hdfd78af_2'
            }
            withName: TRINITY {
                container = 'trinity-rnaseq:latest'
            }
            withName: BUSCO {
                container = 'ezlabgit/busco:v5.4.3_cv1'
            }
            withName: BOWTIE2 {
                container = 'biocontainers/bowtie2:v2.5.1_cv1'
            }
            withName: SALMON {
                container = 'biocontainers/salmon:1.9.0_cv2'
            }
            withName: TRANSDECODER {
                container = 'trinotate/transdecoder:8.1.0'
            }
            withName: MULTIQC {
                container = 'biocontainers/multiqc:1.13_cv1'
            }
        }
    }
    
    singularity {
        singularity.enabled = true
        
        process {
            container = 'library://user/collection/trinity-rnaseq:latest'
        }
    }
    
    slurm {
        process {
            executor = 'slurm'
            cpus = { check_max( 8 * task.attempt, 'cpus' ) }
            memory = { check_max( 60.GB * task.attempt, 'memory' ) }
            time = { check_max( 48.h * task.attempt, 'time' ) }
            queue = 'normal'
            
            withLabel: heavy {
                cpus = { check_max( 32 * task.attempt, 'cpus' ) }
                memory = { check_max( 120.GB * task.attempt, 'memory' ) }
                time = { check_max( 96.h * task.attempt, 'time' ) }
                queue = 'gpu'
            }
        }
    }
}

// Function to ensure that resource requirements don't go beyond a maximum limit
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "   ERROR --max_memory '${params.max_memory}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "   ERROR --max_time '${params.max_time}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min(obj, params.max_cpus as int)
        } catch (all) {
            println "   ERROR --max_cpus '${params.max_cpus}' is not valid! Using default value: $obj"
            return obj
        }
    }
}

// Manifest
manifest {
    name = 'trinity-rnaseq-pipeline'
    author = 'Your Name'
    homePage = 'https://github.com/ChathumadaviE/trinity-rnaseq-pipeline'
    description = 'De novo transcriptome assembly using Trinity'
    mainScript = 'nextflow.nf'
    nextflowVersion = '>=22.10.0'
    version = '1.0'
}

// Timeline and reports
timeline {
    enabled = true
    file = "${params.outdir}/pipeline_execution_timeline.html"
}

report {
    enabled = true
    file = "${params.outdir}/pipeline_execution_report.html"
}

trace {
    enabled = true
    file = "${params.outdir}/pipeline_trace.txt"
    fields = 'task_id,hash,native_id,process,tag,status,exit,module,container,cpus,memory,duration'
}

dag {
    enabled = true
    file = "${params.outdir}/pipeline_dag.svg"
}
